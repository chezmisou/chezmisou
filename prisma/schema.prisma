generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
  SUPER_ADMIN
  CHURCH_MANAGER
}

enum Category {
  RIZ
  SAUCES
  VIANDES
  BOISSONS
  EPICES
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

enum OrderType {
  TRAITEUR
  LUNCH_AFTER_CHURCH
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  phone     String?
  password  String?
  role      Role     @default(CLIENT)
  churchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  church    Church?   @relation(fields: [churchId], references: [id])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String?
  street    String
  city      String
  state     String?
  zipCode   String?
  country   String  @default("Haiti")
  isDefault Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameCreole  String
  description String
  price       Float
  image       String?
  category    Category
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sizes           Size[]
  orderItems      OrderItem[]
  weeklyMenuItems WeeklyMenuItem[]
}

model Size {
  id              String @id @default(cuid())
  label           String
  labelCreole     String
  servings        String
  priceMultiplier Float  @default(1.0)
  productId       String

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Order {
  id              String         @id @default(cuid())
  userId          String?
  guestEmail      String?
  guestPhone      String?
  guestName       String?
  status          OrderStatus    @default(RECEIVED)
  type            OrderType      @default(TRAITEUR)
  deliveryMethod  DeliveryMethod @default(DELIVERY)
  deliveryAddress String?
  addressId       String?
  deliverySlot    String?
  paymentMethod   PaymentMethod  @default(CARD)
  paymentStatus   PaymentStatus  @default(PENDING)
  stripePaymentId String?
  promoCode       String?
  subtotal        Float
  deliveryFee     Float          @default(0)
  discount        Float          @default(0)
  total           Float
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user    User?       @relation(fields: [userId], references: [id])
  address Address?    @relation(fields: [addressId], references: [id])
  items   OrderItem[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  sizeId         String?
  quantity       Int
  customizations Json?
  unitPrice      Float
  totalPrice     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  size    Size?   @relation(fields: [sizeId], references: [id])
}

model WeeklyMenu {
  id            String   @id @default(cuid())
  weekStartDate DateTime
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  items WeeklyMenuItem[]
}

model WeeklyMenuItem {
  id           String  @id @default(cuid())
  weeklyMenuId String
  productId    String
  maxQuantity  Int?
  soldCount    Int     @default(0)
  available    Boolean @default(true)

  weeklyMenu WeeklyMenu @relation(fields: [weeklyMenuId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  validUntil    DateTime?
  maxUses       Int?
  currentUses   Int          @default(0)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
}

model SiteConfig {
  id                  String @id @default(cuid())
  minOrderAmount      Float  @default(10)
  deliveryFee         Float  @default(5)
  freeDeliveryMinimum Float  @default(50)
  deliveryRadiusKm    Float  @default(15)
  sundayDeadline      String @default("Saturday 20:00")
  pickupAddress       String @default("")
  pickupHours         String @default("")
}

// ==================== LAC (Lunch After Church) Models ====================

enum SlotStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RecurrenceFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY_FIRST
  MONTHLY_SECOND
  MONTHLY_THIRD
  MONTHLY_FOURTH
  MONTHLY_LAST
}

model Church {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  contactName  String
  contactEmail String
  contactPhone String?
  address      String?
  city         String?
  logoUrl      String?
  color        String   @default("#6366f1")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accessSlots     AccessSlot[]
  recurrenceRules RecurrenceRule[]
  users           User[]
}

model AccessSlot {
  id              String     @id @default(cuid())
  churchId        String
  date            DateTime
  status          SlotStatus @default(SCHEDULED)
  maxParticipants Int?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, date])
}

model RecurrenceRule {
  id        String              @id @default(cuid())
  churchId  String
  frequency RecurrenceFrequency
  isActive  Boolean             @default(true)
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime            @default(now())

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
}

model LacConfig {
  id                    String  @id @default(cuid())
  maxChurchesPerSunday  Int     @default(1)
  defaultStartTime      String  @default("12:00")
  defaultEndTime        String  @default("15:00")
  reminderEmailsEnabled Boolean @default(true)
  reminderDaysBefore    Int     @default(3)
}

// ==================== Épicerie Fine Models ====================

enum EpicerieCategory {
  EPIS
  PIMENT
  KREMAS
}

model EpicerieCategoryInfo {
  id          String           @id @default(cuid())
  key         EpicerieCategory @unique
  labelFr     String
  labelCr     String
  accentColor String

  products EpicerieProduct[]
}

model EpicerieProduct {
  id          String           @id @default(cuid())
  nameFr      String
  nameCr      String
  category    EpicerieCategory
  size        String
  price       Float
  defaultPrice Float
  image       String           @default("🫙")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  categoryInfo EpicerieCategoryInfo @relation(fields: [category], references: [key])
}

// ==================== LAC Menu (migré depuis JSON vers DB) ====================

model LacMenu {
  id          String   @id @default(uuid())
  key         String   @unique
  type        String   // "menu" ou "supplement"
  nom         String
  description String?
  prix        Decimal  @default(0) @db.Decimal(10, 2)
  devise      String   @default("HTG")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("lac_menu")
}
