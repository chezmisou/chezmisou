generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  admin
}

enum OrderType {
  epicerie
  lac
}

enum OrderStatus {
  new
  paid
  preparing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum DeliveryMethod {
  shipping
  pickup
  local_delivery
}

enum QuoteStatus {
  new
  in_progress
  quote_sent
  accepted
  refused
}

enum DiscountType {
  percentage
  fixed_amount
}

enum PromoAppliesTo {
  all
  epicerie
  lac
  specific_products
}

model CustomerProfile {
  id               String    @id @default(cuid())
  userId           String?   @unique // lien vers Supabase Auth user (nullable pour invités)
  email            String
  firstName        String?
  lastName         String?
  phone            String?
  defaultAddressId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  addresses Address[]
  orders    Order[]
  reviews   ProductReview[]
  quotes    QuoteRequest[]
  redemptions PromoCodeRedemption[]

  @@index([email])
  @@index([userId])
}

model Address {
  id                String  @id @default(cuid())
  customerProfileId String
  line1             String
  line2             String?
  postalCode        String
  city              String
  country           String  @default("FR")
  isDefault         Boolean @default(false)
  createdAt         DateTime @default(now())

  customer CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerProfileId])
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  basePrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images     ProductImage[]
  variants   ProductVariant[]
  reviews    ProductReview[]
  relatedFrom ProductRelated[] @relation("RelatedFrom")
  relatedTo   ProductRelated[] @relation("RelatedTo")
  promoCodes  PromoCodeProduct[]
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  sku       String? @unique
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductReview {
  id                String   @id @default(cuid())
  productId         String
  customerProfileId String
  rating            Int
  comment           String?
  isApproved        Boolean  @default(false)
  createdAt         DateTime @default(now())

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductRelated {
  id              String @id @default(cuid())
  productId       String
  relatedProductId String
  position        Int    @default(0)

  product Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  related Product @relation("RelatedTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
}

model LacMenu {
  id                String   @id @default(cuid())
  serviceDate       DateTime
  orderDeadline     DateTime
  deliveryZoneText  String?
  isPublished       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  dishes LacDish[]

  @@index([serviceDate])
}

model LacDish {
  id          String  @id @default(cuid())
  lacMenuId   String
  name        String
  description String?
  photoUrl    String?
  price       Decimal @db.Decimal(10, 2)
  maxQuantity Int?
  position    Int     @default(0)

  menu LacMenu @relation(fields: [lacMenuId], references: [id], onDelete: Cascade)

  @@index([lacMenuId])
}

model TraiteurDish {
  id          String  @id @default(cuid())
  name        String
  description String?
  photoUrl    String?
  category    String?
  baseInfo    String?
  isActive    Boolean @default(true)
  position    Int     @default(0)
  createdAt   DateTime @default(now())

  formats TraiteurDishFormat[]
}

model TraiteurDishFormat {
  id                       String  @id @default(cuid())
  traiteurDishId           String
  minPeople                Int
  maxPeople                Int
  indicativePricePerPerson Decimal @db.Decimal(10, 2)

  dish TraiteurDish @relation(fields: [traiteurDishId], references: [id], onDelete: Cascade)

  @@index([traiteurDishId])
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique
  type              OrderType
  customerProfileId String?
  guestEmail        String?
  status            OrderStatus    @default(new)
  subtotal          Decimal        @db.Decimal(10, 2)
  shippingCost      Decimal        @default(0) @db.Decimal(10, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(10, 2)
  total             Decimal        @db.Decimal(10, 2)
  promoCodeId       String?
  paymentProvider   String?
  paymentStatus     PaymentStatus  @default(pending)
  stripeSessionId   String?
  deliveryMethod    DeliveryMethod
  shippingAddressId String?
  notes             String?
  lacMenuId         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  customer    CustomerProfile?      @relation(fields: [customerProfileId], references: [id])
  address     Address?              @relation(fields: [shippingAddressId], references: [id])
  promoCode   PromoCode?            @relation(fields: [promoCodeId], references: [id])
  items       OrderItem[]
  redemption  PromoCodeRedemption?

  @@index([customerProfileId])
  @@index([type, status])
}

model OrderItem {
  id               String @id @default(cuid())
  orderId          String
  itemType         String // 'product_variant' | 'lac_dish'
  itemId           String
  itemNameSnapshot String
  itemPriceSnapshot Decimal @db.Decimal(10, 2)
  quantity         Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model QuoteRequest {
  id                String      @id @default(cuid())
  quoteNumber       String      @unique
  customerProfileId String?
  guestName         String
  guestEmail        String
  guestPhone        String?
  eventDate         DateTime
  eventType         String?
  nbPeople          Int
  eventLocation     String?
  selectedDishes    Json
  message           String?
  status            QuoteStatus @default(new)
  adminNotes        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  customer CustomerProfile? @relation(fields: [customerProfileId], references: [id])

  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PromoCode {
  id                     String         @id @default(cuid())
  code                   String         @unique
  description            String?
  discountType           DiscountType
  discountValue          Decimal        @db.Decimal(10, 2)
  minOrderAmount         Decimal?       @db.Decimal(10, 2)
  appliesTo              PromoAppliesTo @default(all)
  usageLimit             Int?
  usageLimitPerCustomer  Int?
  usedCount              Int            @default(0)
  validFrom              DateTime?
  validUntil             DateTime?
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())

  products    PromoCodeProduct[]
  redemptions PromoCodeRedemption[]
  orders      Order[]
}

model PromoCodeProduct {
  promoCodeId String
  productId   String

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, productId])
}

model PromoCodeRedemption {
  id                String   @id @default(cuid())
  promoCodeId       String
  orderId           String   @unique
  customerProfileId String?
  guestEmail        String?
  discountAmount    Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  promoCode PromoCode        @relation(fields: [promoCodeId], references: [id])
  order     Order            @relation(fields: [orderId], references: [id])
  customer  CustomerProfile? @relation(fields: [customerProfileId], references: [id])
}
