// =============================================
// Modèle Prisma à ajouter dans prisma/schema.prisma
// pour la table lac_menu
// =============================================
// Ajoutez ce modèle à la fin de votre fichier schema.prisma
// puis exécutez : npx prisma db pull (pour sync) ou npx prisma generate

model LacMenu {
  id          String   @id @default(uuid())
  key         String   @unique
  type        String   // "menu" ou "supplement"
  nom         String
  description String?
  prix        Decimal  @default(0) @db.Decimal(10, 2)
  devise      String   @default("HTG")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("lac_menu")
}
